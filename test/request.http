@baseUrl = http://localhost:4004

### Generate an invoice PDF
POST {{baseUrl}}/api/v1/templates/aurora-invoice/generate
Content-Type: application/json

{
  "version": "latest",
  "returnMode": "base64",
  "fileName": "invoice-9000001234.pdf",
  "data": {
  "company": { "name": "Aurora Components GmbH", "footerText": "Aurora Components GmbH · Friedrichstraße 88, 10117 Berlin · VAT DE 271 884 552 · www.aurora-components.example" },
  "customer": { "name": "Helvetia Robotics AG", "street": "Bahnhofstrasse 21", "city": "8001 Zürich, Switzerland" },
  "invoice": { "number": "AC-2026-0481", "date": "2026-06-15", "dueDate": "2026-06-29", "currency": "EUR", "poNumber": "PO-CH-77120", "payRef": "PAY;IBAN=DE89370400440532013000;AMT=3603.32;REF=AC-2026-0481" },
  "items": [
    { "material": "AC-SERVO-12", "description": "Servo drive unit, 1.2 kW", "quantity": 4, "price": 340, "total": 1360 },
    { "material": "AC-ENC-04", "description": "Absolute rotary encoder", "quantity": 8, "price": 95, "total": 760 },
    { "material": "AC-CBL-25", "description": "Shielded motor cable, 25 m", "quantity": 6, "price": 48, "total": 288 },
    { "material": "AC-SVC", "description": "Commissioning & calibration", "quantity": 1, "price": 620, "total": 620 }
  ],
  "totals": { "net": 3028, "vat": 575.32, "gross": 3603.32 }
}
}

### Validate data without generating (handy for checking field names)
POST {{baseUrl}}/api/v1/templates/invoice-standard/validate
Content-Type: application/json

{
  "data": {
    "company": { "name": "Example GmbH" },
    "customer": { "name": "Musterkunde GmbH", "street": "Mainzer Landstraße 10", "city": "60329 Frankfurt am Main" },
    "invoice": { "number": "9000001234", "date": "2026-06-03", "currency": "EUR" },
    "items": [{ "material": "MAT-100", "description": "Consulting Service", "quantity": 5, "price": 100, "total": 500 }],
    "totals": { "net": 950, "vat": 180.5, "gross": 1130.5 }
  }
}

