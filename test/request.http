



### ──────────────────────────────────────────────────────────────────────────
### PDF Form Builder — API smoke test
### Every successful write below is stored in HANA (the deployed HDI container).
###
### SETUP (one time): get credentials with these two CF commands:
###     cf create-service-key pdf-form-builder-uaa apikey
###     cf service-key       pdf-form-builder-uaa apikey
### The second command prints JSON. Copy three values into the variables below:
###     "clientid"     -> @clientid
###     "clientsecret" -> @clientsecret
###     "url"          -> @tokenUrl
###
### HOW TO RUN: click the little "Send Request" link that appears above each
### request, top to bottom. Run #1 first (it fetches the token the others use).
### ──────────────────────────────────────────────────────────────────────────

@srv = https://bb2bd51ctrial-dev-pdf-form-builder-srv.cfapps.us10-001.hana.ondemand.com
@tokenUrl = https://bb2bd51ctrial.authentication.us10.hana.ondemand.com
@clientid = sb-pdf-form-builder!t662288
@clientsecret = 


### 1) Get an access token  (run this one FIRST)
# @name login
POST {{tokenUrl}}/oauth/token
Content-Type: application/x-www-form-urlencoded
Authorization: Basic {{clientid}}:{{clientsecret}}

grant_type=client_credentials


### ── AURORA #1 — Nordic Automation AS (Oslo) ───────────────────────────────
POST {{srv}}/api/v1/templates/aurora-invoice/generate
Authorization: Bearer {{login.response.body.access_token}}
Content-Type: application/json

{
  "version": "latest",
  "returnMode": "base64",
  "fileName": "aurora-AC-2026-0517.pdf",
  "data": {
    "company": { "name": "Aurora Components GmbH", "footerText": "Aurora Components GmbH · Friedrichstraße 88, 10117 Berlin · VAT DE 271 884 552 · www.aurora-components.example" },
    "customer": { "name": "Nordic Automation AS", "street": "Storgata 14", "city": "0184 Oslo, Norway" },
    "invoice": { "number": "AC-2026-0517", "date": "2026-06-20", "dueDate": "2026-07-04", "currency": "EUR", "poNumber": "PO-NO-88431", "payRef": "PAY;IBAN=DE89370400440532013000;AMT=4873.05;REF=AC-2026-0517" },
    "items": [
      { "material": "AC-SERVO-22", "description": "Servo drive unit, 2.2 kW", "quantity": 3, "price": 480, "total": 1440 },
      { "material": "AC-PSU-48", "description": "48 V power supply, 1000 W", "quantity": 5, "price": 165, "total": 825 },
      { "material": "AC-HMI-10", "description": "10\" HMI touch panel", "quantity": 2, "price": 540, "total": 1080 },
      { "material": "AC-SVC", "description": "On-site commissioning & training", "quantity": 1, "price": 750, "total": 750 }
    ],
    "totals": { "net": 4095, "vat": 778.05, "gross": 4873.05 }
  }
}


